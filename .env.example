# Copy to .env and adjust as needed. All values are optional; defaults live in
# src/config.py. The pipeline reads these at runtime for reproducibility.

# --- Fetch scope -----------------------------------------------------
# Full public history currently spans 2018 Q1 onward. Narrow the range for a
# fast first run; widen for the complete dataset.
PULSE_MIN_YEAR=2020
PULSE_MAX_YEAR=2024

# --- HTTP behaviour --------------------------------------------------
PULSE_HTTP_WORKERS=12
PULSE_HTTP_TIMEOUT=30
PULSE_HTTP_RETRIES=3
# Set to 0 to force re-download instead of using data/raw/ cache.
PULSE_USE_CACHE=1

# --- Source endpoints (rarely changed) -------------------------------
# PULSE_RAW_BASE=https://raw.githubusercontent.com/PhonePe/pulse/master/data
# PULSE_TREE_API=https://api.github.com/repos/PhonePe/pulse/git/trees/master?recursive=1

# --- Warehouse location ----------------------------------------------
# PULSE_DB_PATH=data/warehouse/pulse.duckdb
